# Azure OpenAI Configuration
# Copy this file to .env and fill in your values

# ── Required ─────────────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# ── Authentication ───────────────────────────────────────────────────────────
# The app uses Entra ID (DefaultAzureCredential) by default — no API key needed.
#
# Local development:
#   1. Run 'az login' — AzureCliCredential is picked up automatically.
#   2. Or set AZURE_OPENAI_API_KEY below for key-based auth.
#
# Azure Container Apps:
#   The User-Assigned Managed Identity and AZURE_CLIENT_ID are set by Bicep.
#   No manual configuration required.
#
# AZURE_OPENAI_API_KEY=              # Optional — only if you prefer key auth

# ── Microsoft Foundry Control Plane (optional) ──────────────────────────────
# Configure project_endpoint and judge_deployment in config/settings.yaml
FOUNDRY_PROJECT_ENDPOINT=https://your-hub.services.ai.azure.com/api/projects/your-project
