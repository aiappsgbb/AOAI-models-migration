# Azure OpenAI Model Migration — Environment Configuration
# Copy this file to .env and fill in your values.
# Change ONLY this file to swap models — zero code changes needed.

# ── Azure OpenAI Resource ─────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.cognitiveservices.azure.com/

# ── RAG Pipeline Model Selection ──────────────────────────────────────────
# Change these to test different migration scenarios.
# The same app code runs with any model — only .env changes.

RAG_SOURCE_MODEL=gpt-4o              # Baseline model (current production)
RAG_TARGET_MODEL=gpt-4.1             # Migration target (new model)
RAG_EMBEDDING_MODEL=text-embedding-3-large  # Embedding model (shared)
RAG_REPHRASER_MODEL=gpt-4o-mini      # Query rephraser (3rd model in pipeline)
RAG_JUDGE_MODEL=gpt-4o               # LLM-as-judge (must differ from target)

# ── Deployment Name Mappings (if different from model names) ──────────────
# Only needed if your Azure deployment names differ from the model names.
# GPT4O_DEPLOYMENT=gpt-4o
# GPT41_DEPLOYMENT=gpt-4.1
# EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ── Foundry Dashboard (optional) ─────────────────────────────────────────
# Set these to upload evaluation results to Azure AI Foundry portal.
# AZURE_AI_PROJECT_ENDPOINT=https://YOUR-ACCOUNT.services.ai.azure.com/api/projects/YOUR-PROJECT
# FOUNDRY_JUDGE_DEPLOYMENT=gpt-4o    # Model deployment for Foundry built-in evaluators
